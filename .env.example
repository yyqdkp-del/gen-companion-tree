# =============================================================================
# gen-companion-tree — 环境变量示例
# 复制为 .env.local 后填写真实值。勿将含密钥的 .env* 提交到 Git。
# 标记说明：【必须】生产/完整功能必备 【可选】按需或本地开发可省略
# =============================================================================

# -----------------------------------------------------------------------------
# Supabase（数据库与鉴权）【必须】
# -----------------------------------------------------------------------------
# 项目 URL（Dashboard → Settings → API）
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxx.supabase.co
# 匿名公钥，用于浏览器与 middleware（可公开）
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
# 服务端密钥，绕过 RLS；仅服务器/Cron 使用，切勿暴露给前端
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# -----------------------------------------------------------------------------
# 应用 URL（OAuth 回调、Cron 内部请求、邮件链接等）【可选】
# -----------------------------------------------------------------------------
# 生产环境建议设为 https://你的域名（无末尾斜杠）。未设置时部分路由会用 Vercel 默认或 request.origin
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app

# -----------------------------------------------------------------------------
# Cron / 计划任务（Vercel Cron 等调用受保护 API）【可选】
# -----------------------------------------------------------------------------
# 与 Vercel Cron 或其它调度器请求的 Authorization: Bearer <token> 一致；未设置时部分 /api/cron/* 会拒绝未授权请求
CRON_SECRET=long-random-string-for-cron-only

# -----------------------------------------------------------------------------
# Anthropic（Claude / 多数 AI 与解析接口）【可选】
# -----------------------------------------------------------------------------
# 未设置时多处使用空字符串，相关 AI 能力不可用
ANTHROPIC_API_KEY=sk-ant-api03-xxxxxxxx

# -----------------------------------------------------------------------------
# Google AI（Gemini）与 xAI（Grok）— 巡查 / Rian worker 等【可选】
# -----------------------------------------------------------------------------
GOOGLE_AI_API_KEY=AIzaSyxxxxxxxx
XAI_API_KEY=xai-xxxxxxxx

# -----------------------------------------------------------------------------
# LINE 登录【可选 — 使用 LINE 登录时服务端为必须】
# -----------------------------------------------------------------------------
# 前端 LINE Login Channel ID（代码内有默认值，生产应显式配置）
NEXT_PUBLIC_LINE_CLIENT_ID=1234567890
# 服务端换 token 用，勿暴露到 NEXT_PUBLIC_
LINE_CLIENT_ID=1234567890
LINE_CLIENT_SECRET=xxxxxxxx

# -----------------------------------------------------------------------------
# Google OAuth（Gmail 等，见 lib/google/oauth.ts）【可选】
# -----------------------------------------------------------------------------
GOOGLE_CLIENT_ID=xxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxxxxxxx

# -----------------------------------------------------------------------------
# Make.com Webhook（Rian / Todo / Email 等集成）【可选】
# -----------------------------------------------------------------------------
NEXT_PUBLIC_MAKE_WEBHOOK_URL=https://hook.eu2.make.com/xxxxxxxx

# -----------------------------------------------------------------------------
# Web Push（VAPID）【可选】
# -----------------------------------------------------------------------------
# 浏览器订阅用公钥（可与下方 VAPID_PUBLIC_KEY 相同）
NEXT_PUBLIC_VAPID_PUBLIC_KEY=BGxxxxxxxx
# 服务端发推送用（与公钥成对）；邮箱用于 Web Push 标准 contact
VAPID_EMAIL=mailto:admin@example.com
VAPID_PUBLIC_KEY=BGxxxxxxxx
VAPID_PRIVATE_KEY=xxxxxxxx

# -----------------------------------------------------------------------------
# 其它安全与运维【可选】
# -----------------------------------------------------------------------------
# 医疗/签证等卡片签名 URL 密钥；未设置时使用内置 fallback（生产务必自定义）
CARDS_URL_SECRET=random-secret-for-signed-card-urls
# 仅 /api/treehouse/migrate-pin 使用；调用该迁移接口时必须与请求头一致
TREEHOUSE_PIN_MIGRATE_SECRET=another-long-random-secret

# -----------------------------------------------------------------------------
# Stripe 订阅（根陪伴 Pro）【可选 — 启用付费时配置】
# -----------------------------------------------------------------------------
# 服务端密钥；用于 Checkout 与 Webhook，切勿暴露给前端
STRIPE_SECRET_KEY=sk_live_xxxxxxxx
# Dashboard → 产品 → Pro 月付 Price ID（price_...）
STRIPE_PRO_PRICE_ID=price_xxxxxxxx
# Dashboard → 开发者 → Webhook → 签名密钥（whsec_...）
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxx
# Stripe.js 公钥；浏览器支付 UI 使用（本仓库已安装 @stripe/stripe-js，可在后续收银台中接入）
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_xxxxxxxx

# -----------------------------------------------------------------------------
# PostHog（产品分析，仅 production 上报）【可选】
# -----------------------------------------------------------------------------
NEXT_PUBLIC_POSTHOG_KEY=phc_xxxxxxxx
NEXT_PUBLIC_POSTHOG_HOST=https://us.posthog.com

# -----------------------------------------------------------------------------
# Vercel 自动注入（一般无需写入 .env.local）【只读参考】
# -----------------------------------------------------------------------------
# 部署在 Vercel 时由平台设置，用于 lib/google/oauth.ts 中拼接回调基址等
# VERCEL_URL=your-project-xxx.vercel.app
